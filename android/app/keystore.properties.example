## Local signing config (DO NOT COMMIT keystore.properties)
#
# Copy this file to `keystore.properties` and fill in real values.
# Suggested: put keystore file under android/app/signature/ and keep it ignored by git.
#
# Path can be relative to android/app/ or absolute.
storeFile=signature/release.keystore
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME

